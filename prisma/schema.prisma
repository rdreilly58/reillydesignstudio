generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CUSTOMER)
  
  // Phase 1: Enhanced Customer Fields
  companyName      String?
  jobTitle         String?
  phone            String?
  website          String?
  industry         String?
  companySize      CompanySize?
  leadSource       LeadSource?
  customerType     CustomerType @default(PROSPECT)
  lifetimeValue    Int?         // in cents
  lastContactDate  DateTime?
  preferredContact PreferredContact @default(EMAIL)
  timezone         String?      @default("America/New_York")
  notes            String?      @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  orders           Order[]
  quotes           Quote[]
  digitalDownloads DigitalDownload[]
  
  // Phase 1: Customer Management Relations
  contacts         CustomerContact[]
  interactions     CustomerInteraction[]
  tags             CustomerTag[]
}

enum UserRole {
  CUSTOMER
  ADMIN
}

// Phase 1: Customer Enhancement Enums
enum CompanySize {
  SOLO
  SMALL_1_10
  MEDIUM_11_50
  LARGE_51_200
  ENTERPRISE_200_PLUS
}

enum LeadSource {
  WEBSITE
  REFERRAL
  LINKEDIN
  GOOGLE_ADS
  NETWORKING
  COLD_OUTREACH
  EXISTING_CLIENT
  OTHER
}

enum CustomerType {
  PROSPECT     // Initial interest
  QUALIFIED    // Meets criteria
  OPPORTUNITY  // Active sales process
  CUSTOMER     // Paying customer
  PARTNER      // Strategic relationship
  DORMANT      // Inactive but keep
}

enum PreferredContact {
  EMAIL
  PHONE
  TEXT
  SLACK
  TEAMS
  WHATSAPP
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String      @db.Text
  price       Int         // in cents
  type        ProductType
  images      String[]    // array of image URLs
  tags        String[]
  published   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Physical only
  stock       Int?
  weight      Float?      // kg
  dimensions  String?     // "L x W x H"

  // Digital only
  fileKey     String?     // S3 key
  fileName    String?

  // Service only
  duration    String?     // e.g. "2-4 weeks"
  deliverables String?    @db.Text

  orderItems  OrderItem[]
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  total           Int         // in cents
  stripePaymentId String?     @unique
  stripeInvoiceId String?
  
  // Shipping (physical orders)
  shippingName    String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?

  // Customer email (for guests)
  email           String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]
  downloads       DigitalDownload[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int     // price at time of purchase, in cents

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ─── Digital Downloads ────────────────────────────────────────────────────────

model DigitalDownload {
  id            String    @id @default(cuid())
  token         String    @unique @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  fileKey       String    // S3 key
  fileName      String
  downloadCount Int       @default(0)
  maxDownloads  Int       @default(5)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
}

// ─── Quotes / Services ────────────────────────────────────────────────────────

model Quote {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  name        String
  email       String
  company     String?
  service     String
  description String      @db.Text
  budget      String?
  timeline    String?
  status            QuoteStatus @default(PENDING)
  adminNotes  String?     @db.Text
  quotedPrice Int?        // in cents
  stripePaymentLink String?
  stripeCustomerId  String?
  stripeSessionId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum QuoteStatus {
  PENDING
  REVIEWING
  SENT
  ACCEPTED
  DECLINED
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Portfolio ────────────────────────────────────────────────────────────────

model PortfolioItem {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String    @db.Text
  images      String[]
  tags        String[]
  client      String?
  year        Int?
  featured    Boolean   @default(false)
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  stripeInvoiceId String        @unique
  customerName    String
  customerEmail   String
  amount          Int           // in cents
  currency        String        @default("usd")
  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime?
  paidAt          DateTime?
  description     String?       @db.Text
  lineItems       Json          // array of {description, amount, quantity}
  stripeHostedUrl String?       // Stripe hosted invoice URL
  qrCodeUrl       String?       @db.Text // QR code as data URL
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTABLE
}

// ─── Job Applications ──────────────────────────────────────────────────────────

model JobApplication {
  id                Int                     @id @default(autoincrement())
  dateApplied       DateTime
  company           String
  jobTitle          String
  status            JobApplicationStatus    @default(APPLIED)
  contactName       String?
  contactEmail      String?
  jobUrl            String?
  notes             String?                 @db.Text
  jobDescription    String?
  
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@map("job_applications")
}

enum JobApplicationStatus {
  APPLIED
  REJECTED
  INTERVIEW_COMPLETED
  RECRUITER_OUTREACH
  PHONE_INTERVIEW_COMPLETED
  PHONE_SCREEN_COMPLETED
  ROUND_2_COMPLETED
  PHONE_SCREEN_PASSED
  RECRUITER_SUBMITTED
  PHONE_INTERVIEW_SCHEDULED
  INTERVIEW_SCHEDULED
  PHONE_SCREEN_SCHEDULED
  ROUND_2_SCHEDULED
  UNDER_REVIEW
  OFFER_RECEIVED
  OFFER_ACCEPTED
  OFFER_DECLINED
  WITHDRAWN
}

// ─── Customer Management (Phase 1) ────────────────────────────────────────────

model CustomerContact {
  id              String  @id @default(cuid())
  customerId      String
  customer        User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  firstName       String
  lastName        String
  fullName        String  // Computed: firstName + lastName
  email           String?
  phone           String?
  jobTitle        String?
  department      String?
  
  isPrimary       Boolean @default(false)
  isDecisionMaker Boolean @default(false)
  isTechnical     Boolean @default(false)
  isBilling       Boolean @default(false)
  
  notes           String? @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  interactions    CustomerInteraction[]
  
  @@unique([customerId, email]) // Prevent duplicate emails per customer
}

model CustomerInteraction {
  id              String           @id @default(cuid())
  customerId      String
  customer        User             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         CustomerContact? @relation(fields: [contactId], references: [id])
  
  type            InteractionType
  subject         String
  description     String           @db.Text
  outcome         String?          @db.Text
  
  // Basic scheduling
  scheduledDate   DateTime?
  completedDate   DateTime?
  
  // Follow-up
  followUpRequired Boolean         @default(false)
  followUpDate     DateTime?
  followUpNotes    String?
  
  // Metadata
  createdBy       String           // User ID who logged this
  source          String?          @default("manual") // "manual", "email", "calendar", etc.
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model CustomerTag {
  id          String @id @default(cuid())
  customerId  String
  customer    User   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  tag         String
  color       String @default("#3B82F6") // Hex color
  
  createdAt   DateTime @default(now())
  
  @@unique([customerId, tag]) // Prevent duplicate tags per customer
}

enum InteractionType {
  EMAIL
  PHONE_CALL
  MEETING
  VIDEO_CALL
  TEXT_MESSAGE
  DEMO
  PROPOSAL_REVIEW
  CONTRACT_DISCUSSION
  CHECK_IN
  FOLLOW_UP
  OTHER
}
